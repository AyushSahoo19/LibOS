---
interface Props {
  title: string;
  description: string;
  domain: string;
  slug: string;
  stars?: number;
}

const { title, description, domain, slug, stars } = Astro.props;
---

<a href={`/library/${slug}`} class="card glass-panel" data-domain={domain.toLowerCase()} data-title={title.toLowerCase()} data-desc={description.toLowerCase()}>
  <div class="card-header">
    <span class="domain-tag">{domain}</span>
    {stars && (
      <div class="stars">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
        {stars > 999 ? (stars/1000).toFixed(1) + 'k' : stars}
      </div>
    )}
  </div>
  <h3 class="title">{title}</h3>
  <p class="description">{description}</p>
  <div class="card-footer">
    <span class="read-more">View Details →</span>
  </div>
</a>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 0.85rem;
    height: 100%;
    cursor: pointer;
    overflow: hidden;
    border-radius: 8px;
    text-decoration: none;

    /* Themed metallic finish */
    background: var(--surface-card);

    /* Themed metal edge */
    border: 1px solid var(--border-metal);

    /* Themed shadow */
    box-shadow:
      0 1px 0 0 rgba(255,255,255,var(--inset-glow-opacity, 0.05)) inset,
      0 -1px 0 0 rgba(0,0,0,var(--inset-shadow-opacity, 0.8)) inset,
      var(--card-shadow);

    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.2s ease,
                border-color 0.2s ease,
                background 0.3s ease;
  }

  :global([data-theme="light"]) .card {
    --inset-glow-opacity: 0.8;
    --inset-shadow-opacity: 0.1;
  }

  /* Top-edge catch-light — simulates light hitting polished metal */
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(200, 200, 255, 0.2) 30%,
      rgba(200, 200, 255, 0.4) 50%,
      rgba(200, 200, 255, 0.2) 70%,
      transparent 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* Hover shimmer sweep */
  .card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(255, 255, 255, 0.1) 50%,
      transparent 100%
    );
    transition: left 0.55s ease;
    pointer-events: none;
    z-index: 0;
  }

  .card > * {
    position: relative;
    z-index: 1;
  }

  .card:hover {
    transform: translateY(-2px);
    border-color: var(--accent-neon);
    box-shadow:
      0 1px 0 0 rgba(255,255,255,0.2) inset,
      0 8px 24px rgba(0,0,0,0.15),
      0 0 0 1px var(--accent-neon);
  }

  /* Shimmer sweep plays on hover */
  .card:hover::after {
    left: 125%;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .domain-tag {
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--surface-hover);
    color: var(--text-secondary);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 700;
    border: 1px solid var(--border-color);
  }

  .stars {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.65rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .title {
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
    color: var(--text-primary);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .description {
    color: var(--text-secondary);
    font-size: 0.75rem;
    line-height: 1.4;
    flex-grow: 1;
    margin-bottom: 0.75rem;
  }

  .card-footer {
    border-top: 1px solid var(--border-color);
    padding-top: 0.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .read-more {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.15s ease;
  }

  .card:hover .read-more {
    color: var(--accent-neon);
  }
</style>
