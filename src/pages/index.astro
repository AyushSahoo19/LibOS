    </div>
  </section>

  <!-- Ecosystem Pulse chart — full width below directory -->
  <section class="container metrics-section">
    <div class="metrics-label">
      <span class="metrics-label-line"></span>
      <span class="metrics-label-text">Ecosystem Pulse</span>
      <span class="metrics-label-line"></span>
    </div>
    <TerminalChart />
  </section>

</Layout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;
  const filterBar = document.getElementById('filter-bar');
  const grid = document.getElementById('card-grid');
  const emptyState = document.getElementById('empty-state');

  let activeFilter = 'all';
  let searchQuery = '';

  function applyFilters() {
    const cards = grid!.querySelectorAll<HTMLAnchorElement>('.card');
    let visibleCount = 0;

    cards.forEach(card => {
      const domain = card.dataset.domain || '';
      const title = card.dataset.title || '';
      const desc = card.dataset.desc || '';

      const matchesDomain = activeFilter === 'all' || domain === activeFilter;
      const matchesSearch = searchQuery === '' ||
        title.includes(searchQuery) ||
        desc.includes(searchQuery);

      const show = matchesDomain && matchesSearch;
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    emptyState!.style.display = visibleCount === 0 ? 'flex' : 'none';
    // Dim the clear button when no query
    clearBtn!.style.opacity = searchQuery ? '1' : '0.3';
  }

  // Search input — live filter
  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    applyFilters();
  });

  // Clear button
  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    searchQuery = '';
    applyFilters();
    searchInput.focus();
  });

  // Filter buttons
  filterBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.filter-btn');
    if (!btn) return;

    filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.filter || 'all';
    applyFilters();
  });

  // Best Collections Interactive Scroller (Native Scroll Edition)
  const setupCollectionScroller = () => {
    const wrapper = document.querySelector('.bc-scroll-wrapper') as HTMLElement | null;
    const list = document.querySelector('.bc-list') as HTMLElement | null;
    if (!wrapper || !list) return;

    let isDown = false;
    let startX: number;
    let scrollLeft: number;
    let isHovered = false;
    let animationId: number;

    // Auto-scroll speed (pixels per frame)
    const speed = 0.5; 

    const scroll = () => {
      if (!isDown && !isHovered) {
        wrapper.scrollLeft += speed;
        
        // Native "Teleport" Loop
        // Since we duplicated items, we reset when we pass the first set
        const halfWidth = list.scrollWidth / 2;
        if (wrapper.scrollLeft >= halfWidth) {
          wrapper.scrollLeft = 0;
        }
      }
      animationId = requestAnimationFrame(scroll);
    };

    // Start auto-scroll
    scroll();

    // Mouse Events for Drag
    wrapper.addEventListener('mousedown', (e) => {
      const mouseEvent = e as MouseEvent;
      isDown = true;
      startX = mouseEvent.pageX - wrapper.offsetLeft;
      scrollLeft = wrapper.scrollLeft;
      wrapper.classList.add('grabbing');
    });

    wrapper.addEventListener('mouseleave', () => {
      isDown = false;
      isHovered = false;
      wrapper.classList.remove('grabbing');
    });

    wrapper.addEventListener('mouseenter', () => {
      isHovered = true;
    });

    window.addEventListener('mouseup', () => {
      isDown = false;
      wrapper.classList.remove('grabbing');
    });

    // Native wheel support is built-in, no need for manual translate
    // We only need to handle the infinite loop during manual sliding/scrolling
    wrapper.addEventListener('scroll', () => {
      const halfWidth = list.scrollWidth / 2;
      if (wrapper.scrollLeft >= halfWidth) {
        wrapper.scrollLeft = 1; // 1 instead of 0 to avoid jitter
      } else if (wrapper.scrollLeft <= 0) {
        wrapper.scrollLeft = halfWidth - 1;
      }
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const mouseEvent = e as MouseEvent;
      const x = mouseEvent.pageX - wrapper.offsetLeft;
      const walk = (x - startX) * 1.5; // multiplier for drag sensitivity
      wrapper.scrollLeft = scrollLeft - walk;
    });
  };

  // Initialize all client-side logic
  applyFilters();
  setupCollectionScroller();
</script>

<style is:global>
  .hero {
    position: relative;
    padding: 6rem 0 5rem;
    text-align: center;
    overflow: visible;
  }

  .hero-glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
    opacity: 0.8;
    animation: glowBreathe 8s ease-in-out infinite;
  }

  /* ─── Hero Decorative Background ───────────────────────── */
  .hero-stars {
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(1.5px 1.5px at 10% 20%, var(--accent-neon), transparent),
      radial-gradient(1.5px 1.5px at 30% 50%, white, transparent),
      radial-gradient(1.5px 1.5px at 50% 80%, var(--accent-neon), transparent),
      radial-gradient(2px 2px at 80% 30%, white, transparent),
      radial-gradient(1.5px 1.5px at 90% 10%, var(--accent-neon), transparent),
      radial-gradient(1.5px 1.5px at 20% 70%, white, transparent);
    background-size: 200% 200%;
    opacity: 0.25;
    z-index: -1;
    pointer-events: none;
    animation: starsDrift 100s linear infinite;
    filter: drop-shadow(0 0 2px var(--accent-glow));
  }

  @keyframes starsDrift {
    0% { background-position: 0% 0%; }
    100% { background-position: 100% 100%; }
  }

  .hero-bg-icons {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-icon {
    position: absolute;
    color: var(--text-primary);
    opacity: 0.06;
    filter: blur(1px);
    animation: floatIcon 20s ease-in-out infinite;
  }

  .icon-1 { top: 15%; left: 10%; animation-delay: 0s; }
  .icon-2 { top: 60%; left: 15%; animation-delay: -5s; transform: rotate(15deg); }
  .icon-3 { top: 25%; right: 12%; animation-delay: -2s; transform: rotate(-10deg); }
  .icon-4 { top: 70%; right: 18%; animation-delay: -12s; transform: rotate(5deg); }

  @keyframes floatIcon {
    0%, 100% { transform: translateY(0) rotate(var(--rot, 0deg)); }
    50% { transform: translateY(-20px) rotate(calc(var(--rot, 0deg) + 5deg)); }
  }

  @keyframes glowBreathe {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.7; }
    50% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
  }

  @keyframes slideFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-content h1 {
    font-size: 4rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.04em;
    font-weight: 800;
    opacity: 0;
    animation: slideFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 650px;
    margin: 0 auto 3rem;
    line-height: 1.6;
    opacity: 0;
    animation: slideFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  }

  .search-bar {
    display: flex;
    gap: 1rem;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
    opacity: 0;
    animation: slideFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  .glass-input {
    flex-grow: 1;
    padding: 0.8rem 1.25rem;
    border-radius: 8px;
