---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import TerminalChart from '../components/TerminalChart.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('library');
const collections = await getCollection('collections');

// Calculate repo counts per collection (Supporting multiple collection tags)
const collectionCounts = collections.reduce((acc, col) => {
  acc[col.id] = allEntries.filter(entry => {
    const c = entry.data.collection;
    if (!c) return false;
    if (Array.isArray(c)) return c.includes(col.id);
    return c === col.id;
  }).length;
  return acc;
}, {} as Record<string, number>);

// Predefined domains for a structured filter experience
const domains = ["Framework", "Tool", "Repository", "Workflow", "AI Agent", "Machine Learning", "Robotics", "Quantum Computing", "Physics Engine", "Chemistry", "Trading", "3D Software", "Library", "Math"];

// Mock Top Profiles (Diverse Innovators)
const topProfiles = [
  { name: "Linus Torvalds", role: "Kernel Creator", project: "Linux / Git", initials: "LT", github: "https://github.com/torvalds" },
  { name: "Yann LeCun", role: "Chief AI Scientist", project: "PyTorch", initials: "YL", github: "https://github.com/ylecun" },
  { name: "Guillermo Rauch", role: "Vercel CEO", project: "Next.js", initials: "GR", github: "https://github.com/rauchg" },
  { name: "Ton Roosendaal", role: "Chairman", project: "Blender", initials: "TR", github: "https://github.com/tonroosendaal" },
  { name: "Emanuel Todorov", role: "Founder", project: "MuJoCo", initials: "ET", github: "https://github.com/google-deepmind/mujoco" },
  { name: "Greg Landrum", role: "Creator", project: "RDKit", initials: "GL", github: "https://github.com/greglandrum" }
];

const trendingStacks = [
  { name: "React + Tailwind", usage: "32% growth", icon: "⚛️" },
  { name: "Python + PyTorch", usage: "45% growth", icon: "🐍" },
  { name: "Rust + Wasm", usage: "18% growth", icon: "🦀" },
  { name: "C++ + MuJoCo", usage: "Physics Research", icon: "⚙️" }
];
---

