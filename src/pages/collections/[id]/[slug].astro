---
import Layout from '../../../layouts/Layout.astro';
import Card from '../../../components/Card.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const playbooks = await getCollection('playbooks');
  const collections = await getCollection('collections');

  return playbooks.map(playbook => {
    const parentCollection = collections.find(c => c.id === playbook.data.collectionId);
    return {
      params: { 
        id: playbook.data.collectionId,
        slug: playbook.id 
      },
      props: { playbook, collection: parentCollection },
    };
  });
}

const { playbook, collection } = Astro.props;
const { Content } = await render(playbook);

const allPlaybooks = await getCollection('playbooks');
const collectionPlaybooks = allPlaybooks
  .filter(p => p.data.collectionId === collection.id)
  .sort((a, b) => a.data.order - b.data.order);

const allLibraryEntries = await getCollection('library');
const entries = allLibraryEntries.filter(entry => {
  const col = entry.data.collection;
  if (!col) return false;
  if (Array.isArray(col)) return col.includes(collection.id);
  return col === collection.id;
});
---

<Layout title={`${playbook.data.title} | ${collection.data.title} | LibOS`}>
  <div class="doc-layout container">
    <!-- Sidebar -->
    <aside class="doc-sidebar">
      <div class="sidebar-sticky">
        <div class="sidebar-header">
          <span class="sidebar-icon">{collection.data.icon}</span>
          <h2 class="sidebar-title">Playbook</h2>
        </div>
        
        <nav class="sidebar-nav">
          <div class="nav-section">
            <h4 class="nav-label">Core Guide</h4>
            <a href={`/collections/${collection.id}`} class="nav-link">Overview</a>
          </div>

          <div class="nav-section">
            <h4 class="nav-label">Guides & Workflows</h4>
            {collectionPlaybooks.map(p => (
              <a 
                href={`/collections/${collection.id}/${p.id}`} 
                class={`nav-link ${p.id === playbook.id ? 'active' : ''}`}
              >
                {p.data.title}
              </a>
            ))}
          </div>

          <div class="nav-section">
            <h4 class="nav-label">Repositories</h4>
            <div class="nav-repo-list">
              {entries.map(entry => (
                <a href={`/collections/${collection.id}#repo-${entry.id}`} class="nav-link-sm">
                  {entry.data.title}
                </a>
              ))}
            </div>
          </div>
        </nav>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="doc-content">
      <div class="breadcrumb">
        <a href="/collections">Playbooks</a> / 
        <a href={`/collections/${collection.id}`}>{collection.data.title}</a> / 
        <span>{playbook.data.title}</span>
      </div>

      <header class="doc-header">
        <div class="category-badge">{playbook.data.category}</div>
        <h1 class="text-gradient">{playbook.data.title}</h1>
        <p class="lead">{playbook.data.description}</p>
      </header>

      <div class="doc-body prose">
        <Content />
      </div>

      <section class="doc-repositories" id="repositories">
        <div class="section-divider">
          <span>Repository Stack</span>
        </div>
        
        <div class="doc-grid">
          {entries.map((entry) => (
            <div id={`repo-${entry.id}`} class="anchor-offset">
              <Card 
                title={entry.data.title}
                description={entry.data.description}
                domain={entry.data.domain}
                slug={entry.id}
                stars={entry.data.stars}
              />
            </div>
          ))}
        </div>
      </section>

      <footer class="doc-footer-nav">
        {collectionPlaybooks.findIndex(p => p.id === playbook.id) > 0 && (
          <a href={`/collections/${collection.id}/${collectionPlaybooks[collectionPlaybooks.findIndex(p => p.id === playbook.id) - 1].id}`} class="prev-guide">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{collectionPlaybooks[collectionPlaybooks.findIndex(p => p.id === playbook.id) - 1].data.title}</span>
          </a>
        )}
        {collectionPlaybooks.findIndex(p => p.id === playbook.id) < collectionPlaybooks.length - 1 && (
          <a href={`/collections/${collection.id}/${collectionPlaybooks[collectionPlaybooks.findIndex(p => p.id === playbook.id) + 1].id}`} class="next-guide">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{collectionPlaybooks[collectionPlaybooks.findIndex(p => p.id === playbook.id) + 1].data.title}</span>
          </a>
        )}
      </footer>
    </main>
  </div>
</Layout>

<style is:global>
  .doc-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 4rem;
    padding-top: 4rem;
    padding-bottom: 8rem;
    min-height: 100vh;
  }

  /* Sidebar */
  .doc-sidebar {
    position: relative;
  }

  .sidebar-sticky {
    position: sticky;
    top: 100px;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-icon {
    font-size: 1.5rem;
  }

  .sidebar-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    opacity: 0.6;
    font-weight: 700;
  }

  .nav-link {
    display: block;
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.4rem 0;
    transition: all 0.2s ease;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--accent-neon);
    padding-left: 0.25rem;
  }

  .nav-repo-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .nav-link-sm {
    display: block;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: all 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-left: 1px solid transparent;
    padding-left: 0.75rem;
  }

  .nav-link-sm:hover {
    color: var(--text-primary);
    border-left-color: var(--accent-neon);
    padding-left: 1rem;
  }

  /* Content */
  .doc-content {
    max-width: 800px;
  }

  .breadcrumb {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .doc-header {
    margin-bottom: 4rem;
  }

  .doc-header h1 {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .category-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(57, 255, 20, 0.1);
    color: var(--accent-neon);
    border: 1px solid rgba(57, 255, 20, 0.2);
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  /* Prose Styles */
  .prose {
    color: var(--text-primary);
    line-height: 1.8;
  }

  .prose h2 {
    font-size: 1.75rem;
    margin: 3rem 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  .prose h3 {
    font-size: 1.25rem;
    margin: 2rem 0 1rem;
    color: var(--accent-neon);
  }

  .prose p {
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
  }

  .prose ul {
    margin-bottom: 1.5rem;
    padding-left: 1.25rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }

  /* Repo Grid */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 6rem 0 3rem;
  }

  .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-color);
  }

  .section-divider span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .anchor-offset {
    scroll-margin-top: 120px;
  }

  .doc-footer-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 6rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    gap: 2rem;
  }

  .prev-guide, .next-guide {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    max-width: 45%;
  }

  .next-guide {
    text-align: right;
    align-items: flex-end;
    margin-left: auto;
  }

  .nav-dir {
    font-size: 0.7rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .nav-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  .prev-guide:hover .nav-title, .next-guide:hover .nav-title {
    color: var(--accent-neon);
  }

  @media (max-width: 1024px) {
    .doc-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .doc-sidebar {
      display: none;
    }
  }
</style>
